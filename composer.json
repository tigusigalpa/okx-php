{
    "name": "tigusigalpa/okx-php",
    "description": "A production-grade PHP/Laravel SDK for the OKX v5 API.",
    "type": "library",
    "license": "MIT",
    "authors": [
        {
            "name": "Igor Sazonov",
            "email": "sovletig@gmail.com"
        }
    ],
    "require": {
        "php": "^8.2",
        "guzzlehttp/guzzle": "^7.0",
        "textalk/websocket": "^1.6",
        "psr/log": "^3.0"
    },
    "require-dev": {
        "phpunit/phpunit": "^11.0",
        "laravel/framework": "^11.0|^12.0"
    },
    "autoload": {
        "psr-4": {
            "Tigusigalpa\\OKX\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Tigusigalpa\\OKX\\Tests\\": "tests/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "Tigusigalpa\\OKX\\OKXServiceProvider"
            ],
            "aliases": {
                "OKX": "Tigusigalpa\\OKX\\Facades\\OKX"
            }
        }
    },
    "minimum-stability": "stable"
}
